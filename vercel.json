{
  "name": "price-compare-hub",
  "version": 2,
  "builds": [
    {
      "src": "price-compare-hub/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "price-compare-hub/frontend/dist"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "price-compare-hub/frontend/$1" }
  ]
}
